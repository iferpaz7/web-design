---
import type { SyllabusTema, SyllabusUnit } from '../data/syllabus';

interface Props {
  unit: SyllabusUnit;
  tema: SyllabusTema;
}

const { unit, tema } = Astro.props;
const presentationHref = `/presentacion${tema.href}`;
const nextTema = unit.temas.find((item) => item.numero === tema.numero + 1);
const continuity = nextTema
  ? `Próximo tema: ${nextTema.titulo}.`
  : unit.numero < 4
    ? `Este tema cierra la Unidad ${unit.numero}. El siguiente paso es avanzar a la Unidad ${unit.numero + 1}.`
    : 'Este tema cierra la última unidad y prepara la presentación final y el examen bimestral.';
---

<main class="bg-white text-gray-900">
  <section data-print-toolbar class="sticky top-0 z-10 border-b border-gray-200 bg-white/95 backdrop-blur print:hidden">
    <div class="mx-auto flex max-w-5xl flex-col gap-3 px-6 py-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-gray-500">Modo imprimible</p>
        <h1 class="mt-1 text-lg font-bold text-gray-900">Unidad {unit.numero} · Tema {tema.numero}</h1>
      </div>
      <div class="flex flex-wrap gap-3">
        <a
          href={tema.href}
          class="rounded-full border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 transition hover:border-gray-400 hover:bg-gray-50"
        >
          Volver a la guía
        </a>
        <a
          href={presentationHref}
          class="rounded-full border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 transition hover:border-gray-400 hover:bg-gray-50"
        >
          Ir a exposición
        </a>
        <button
          type="button"
          data-print-action
          class="rounded-full bg-gray-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-gray-700"
        >
          Imprimir o guardar PDF
        </button>
      </div>
    </div>
  </section>

  <article class="mx-auto max-w-5xl px-6 py-8 sm:py-12 print:max-w-none print:px-0 print:py-0">
    <header class="rounded-3xl border border-gray-200 bg-gray-50 p-8 print:rounded-none print:border-0 print:bg-white print:p-0">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gray-500">Diseño Web · ITSAE</p>
      <h1 class="mt-3 text-3xl font-bold text-gray-900 sm:text-4xl">{tema.titulo}</h1>
      <p class="mt-2 text-lg text-gray-600">Unidad {unit.numero}: {unit.titulo}</p>
      <p class="mt-6 text-base leading-relaxed text-gray-700">{tema.panorama}</p>
    </header>

    <section class="mt-8 grid gap-6 md:grid-cols-2 print:mt-6 print:grid-cols-2">
      <div class="rounded-2xl border border-gray-200 p-6 print:break-inside-avoid">
        <h2 class="text-lg font-bold text-gray-900">Descripción del tema</h2>
        <p class="mt-3 text-sm leading-relaxed text-gray-700">{tema.descripcion}</p>
      </div>
      <div class="rounded-2xl border border-gray-200 p-6 print:break-inside-avoid">
        <h2 class="text-lg font-bold text-gray-900">Relación con la unidad</h2>
        <p class="mt-3 text-sm leading-relaxed text-gray-700"><strong>Capacidad:</strong> {unit.capacidad}</p>
        <p class="mt-3 text-sm leading-relaxed text-gray-700"><strong>Evidencia de la unidad:</strong> {unit.evidencia}</p>
      </div>
    </section>

    <section class="mt-8 rounded-2xl border border-gray-200 p-6 print:break-inside-avoid">
      <h2 class="text-lg font-bold text-gray-900">Objetivos de aprendizaje</h2>
      <ul class="mt-4 space-y-2 text-sm leading-relaxed text-gray-700">
        {tema.objetivos.map((objetivo) => <li>• {objetivo}</li>)}
      </ul>
    </section>

    <section class="mt-8 rounded-2xl border border-gray-200 p-6 print:break-inside-avoid">
      <h2 class="text-lg font-bold text-gray-900">Ideas clave</h2>
      <ul class="mt-4 space-y-2 text-sm leading-relaxed text-gray-700">
        {tema.ideasClave.map((idea) => <li>• {idea}</li>)}
      </ul>
    </section>

    {tema.presentationBlocks && tema.presentationBlocks.length > 0 && (
      <section class="mt-8 space-y-4">
        <h2 class="text-lg font-bold text-gray-900">Bloques didácticos para clase</h2>
        {tema.presentationBlocks.map((block) => (
          <div class="rounded-2xl border border-gray-200 p-6 print:break-inside-avoid">
            <h3 class="text-base font-bold text-gray-900">{block.title}</h3>
            <ul class="mt-3 space-y-2 text-sm leading-relaxed text-gray-700">
              {block.items.map((item) => <li>• {item}</li>)}
            </ul>
          </div>
        ))}
      </section>
    )}

    <section class="mt-8 grid gap-6 md:grid-cols-2 print:grid-cols-2">
      <div class="rounded-2xl border border-gray-200 p-6 print:break-inside-avoid">
        <h2 class="text-lg font-bold text-gray-900">Actividad sugerida</h2>
        <p class="mt-3 text-sm leading-relaxed text-gray-700">{tema.actividad}</p>
      </div>
      <div class="rounded-2xl border border-gray-200 p-6 print:break-inside-avoid">
        <h2 class="text-lg font-bold text-gray-900">Criterio de evidencia</h2>
        <p class="mt-3 text-sm leading-relaxed text-gray-700">{tema.evidencia}</p>
      </div>
    </section>

    <section class="mt-8 rounded-2xl border border-gray-200 p-6 print:break-inside-avoid">
      <h2 class="text-lg font-bold text-gray-900">Herramientas y recursos</h2>
      <ul class="mt-4 grid gap-2 text-sm leading-relaxed text-gray-700 md:grid-cols-2 print:grid-cols-2">
        {tema.herramientas.map((herramienta) => <li>• {herramienta}</li>)}
      </ul>
    </section>

    <section class="mt-8 rounded-2xl border border-gray-200 p-6 print:break-inside-avoid">
      <h2 class="text-lg font-bold text-gray-900">Continuidad del curso</h2>
      <p class="mt-3 text-sm leading-relaxed text-gray-700">
        Este contenido está alineado con el sílabo actualizado del curso y con una secuencia de trabajo que prioriza estrategia, prototipado, publicación viable y mejora continua.
      </p>
      <p class="mt-3 text-sm leading-relaxed text-gray-700">{continuity}</p>
    </section>
  </article>
</main>

<script>
  const printButton = document.querySelector<HTMLButtonElement>('[data-print-action]');
  printButton?.addEventListener('click', () => window.print());
</script>

<style is:inline>
  @page {
    size: A4;
    margin: 16mm;
  }

  @media print {
    html,
    body {
      background: #ffffff !important;
      color: #111827 !important;
    }

    [data-print-toolbar] {
      display: none !important;
    }

    article {
      max-width: none !important;
    }
  }
</style>