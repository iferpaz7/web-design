---
import Layout from '../../layouts/Layout.astro';
import TemaDetalle from '../../components/TemaDetalle.astro';
import { syllabusUnits } from '../../data/syllabus';

const unit = syllabusUnits[3];
const tema = unit.temas[2];
---

<Layout title={`Unidad ${unit.numero} - Tema ${tema.numero}: ${tema.titulo} - ITSAE`}>
  <TemaDetalle unit={unit} tema={tema} />
</Layout>